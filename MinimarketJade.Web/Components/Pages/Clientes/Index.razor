@page "/clientes"
@using MinimarketJade.Web.Data.Entities
@using MinimarketJade.Web.Services.Clientes
@using MinimarketJade.Web.Services
@inject IVentaService VentaService
@using MinimarketJade.Web.Services.Auth
@rendermode InteractiveServer
@inject IClienteService ClienteService
@inject AuthService Auth

<PageTitle>Clientes - Minimarket Jade</PageTitle>

<h2>Clientes</h2>

<button class="btn btn-primary mb-3" @onclick="NuevoCliente">
    Nuevo Cliente
</button>

<div class="row mb-3">

    <div class="col-3">
        <select class="form-select" @bind="tipoBusqueda">
            <option value="Id">Buscar por ID</option>
            <option value="Documento">Buscar por Documento</option>
            <option value="Nombre">Buscar por Nombre</option>
            <option value="Recurrentes">Clientes Recurrentes</option>
            <option value="NoRecurrentes">Clientes No Recurrentes</option>
        </select>
    </div>

    @if (tipoBusqueda != "Recurrentes" && tipoBusqueda != "NoRecurrentes")
    {
        <div class="col">
            <input class="form-control"
                   placeholder="Escriba para buscar..."
                   @bind="textoBusqueda"
                   @bind:event="oninput" />
        </div>
    }

</div>

@if (mostrarFormulario)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        @(clienteActual.IdCliente == 0 ? "Nuevo Cliente" : "Editar Cliente")
                    </h5>
                    <button class="btn-close" @onclick="Cancelar"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(mensajeError))
                    {
                        <div class="alert alert-danger">
                            @mensajeError
                        </div>
                    }
                    <EditForm Model="clienteActual" OnValidSubmit="Guardar">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-2">
                            <label>Documento</label>
                            <InputText class="form-control" @bind-Value="clienteActual.DocumentoIdentidad" />
                        </div>

                        <div class="mb-2">
                            <label>Nombre</label>
                            <InputText class="form-control" @bind-Value="clienteActual.NombreCompleto" />
                        </div>

                        <div class="mb-2">
                            <label>Telťfono</label>
                            <InputText class="form-control" @bind-Value="clienteActual.Telefono" />
                        </div>

                        <div class="mb-2">
                            <label>Email</label>
                            <InputText class="form-control" @bind-Value="clienteActual.Email" />
                        </div>

                        <div class="mb-2">
                            <label>Direcciťn</label>
                            <InputText class="form-control" @bind-Value="clienteActual.Direccion" />
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                                Cancelar
                            </button>
                            <button type="submit" class="btn btn-success">
                                Guardar
                            </button>
                        </div>
                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@if (clientes == null)
{
    <p>Cargando clientes...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Documento</th>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in clientesFiltrados)
            {
                var estaDeshabilitado = !c.Activo;

                <tr class="@(estaDeshabilitado ? "table-secondary" : "")"
                    style="cursor:pointer"
                    @onclick="() => VerHistorial(c.IdCliente)">

                    <td>@c.IdCliente</td>
                    <td>@c.DocumentoIdentidad</td>
                    <td>@c.NombreCompleto</td>
                    <td>@c.Telefono</td>
                    <td>@c.Email</td>
                    <td>@(estaDeshabilitado ? "Deshabilitado" : "Activo")</td>

                    <td>
                        <button class="btn btn-warning btn-sm me-2"
                                @onclick="() => Editar(c)"
                                @onclick:stopPropagation="true"
                                disabled="@estaDeshabilitado">
                            Editar
                        </button>

                        @if (Auth.IsAdministrador)
                        {
                            <button class="btn @(estaDeshabilitado ? "btn-success" : "btn-danger") btn-sm"
                                    @onclick="() => CambiarEstado(c.IdCliente)">
                                @(estaDeshabilitado ? "Habilitar" : "Deshabilitar")
                            </button>
                        }
                    </td>
                </tr>

                @if (clienteSeleccionadoId == c.IdCliente)
                {
                    <tr class="table-light">
                        <td colspan="7">

                            @if (historialVentas == null)
                            {
                                <p class="text-muted">Cargando historial...</p>
                            }
                            else if (!historialVentas.Any())
                            {
                                <div class="alert alert-info m-2">
                                    Este cliente no tiene compras registradas.
                                </div>
                            }
                            else
                            {
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Vendedor</th>
                                            <th>Total</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var v in historialVentas)
                                        {
                                            <tr>
                                                <td>@v.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>@v.IdVendedorNavigation.NombreUsuario</td>
                                                <td>@v.Total.ToString("N2") Bs</td>
                                                <td>@(v.Anulada ? "Anulada" : "Completada")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }

                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {

    private List<Cliente>? clientes;
    private Cliente clienteActual = new();
    private bool mostrarFormulario = false;
    private string? mensajeError;
    private string textoBusqueda = "";
    private List<Ventum>? historialVentas;
    private int? clienteSeleccionadoId;
    private string tipoBusqueda = "Id";

    private IEnumerable<Cliente> clientesFiltrados
    {
        get
        {
            if (clientes == null)
                return new List<Cliente>();

            IEnumerable<Cliente> resultado = clientes;

            switch (tipoBusqueda)
            {
                case "Id":
                    resultado = clientes.Where(c =>
                        string.IsNullOrWhiteSpace(textoBusqueda) ||
                        c.IdCliente.ToString().Contains(textoBusqueda));
                    break;

                case "Documento":
                    resultado = clientes.Where(c =>
                        string.IsNullOrWhiteSpace(textoBusqueda) ||
                        c.DocumentoIdentidad.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase));
                    break;

                case "Nombre":
                    resultado = clientes.Where(c =>
                        string.IsNullOrWhiteSpace(textoBusqueda) ||
                        c.NombreCompleto.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase));
                    break;

                case "Recurrentes":
                    resultado = clientes.Where(c =>
                        c.Venta.Count(v => !v.Anulada) >= 5);
                    break;

                case "NoRecurrentes":
                    resultado = clientes.Where(c =>
                        c.Venta.Count(v => !v.Anulada) < 5);
                    break;
            }

            return resultado;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        clientes = await ClienteService.ObtenerTodosAsync();
    }

    private void NuevoCliente()
    {
        clienteActual = new Cliente();
        mostrarFormulario = true;
    }

    private void Editar(Cliente cliente)
    {
        clienteActual = new Cliente
        {
            IdCliente = cliente.IdCliente,
            DocumentoIdentidad = cliente.DocumentoIdentidad,
            NombreCompleto = cliente.NombreCompleto,
            Telefono = cliente.Telefono,
            Email = cliente.Email,
            Direccion = cliente.Direccion
        };

        mostrarFormulario = true;
    }

    private async Task Guardar()
    {
        mensajeError = null;

        if (clienteActual.IdCliente == 0)
        {
            var creado = await ClienteService.CrearAsync(clienteActual);

            if (!creado)
            {
                mensajeError = "Este cliente ya existe con exactamente los mismos datos o Documento.";
                return;
            }
        }
        else
        {
            var actualizado = await ClienteService.ActualizarAsync(clienteActual);

            if (!actualizado)
            {
                mensajeError = "Ya existe un cliente con ese documento.";
                return;
            }
        }

        mostrarFormulario = false;
        await CargarClientes();
    }

    private async Task CambiarEstado(int id)
    {
        historialVentas = null;
        clienteSeleccionadoId = null;

        await ClienteService.CambiarEstadoAsync(id);

        await Task.Delay(50);

        await CargarClientes();
    }

    private async Task VerHistorial(int idCliente)
    {
        if (clienteSeleccionadoId == idCliente)
        {
            clienteSeleccionadoId = null;
            historialVentas = null;
            return;
        }

        clienteSeleccionadoId = idCliente;
        historialVentas = await VentaService.GetByClienteAsync(idCliente);
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
    }
}