@page "/productos"
@using MinimarketJade.Web.Data.Entities
@using MinimarketJade.Web.Services
@using MinimarketJade.Web.Services.Categorias
@using MinimarketJade.Web.Helpers
@rendermode InteractiveServer

<PageTitle>Productos - Minimarket Jade</PageTitle>

<div class="container-fluid mt-3 px-4">

    <div class="prod-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold m-0 d-flex align-items-center"><i class="bi bi-box-seam me-3"></i>Catálogo de Productos</h2>
            <p class="m-0 opacity-75 small">Gestión de inventario y precios</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border bg-white" style="width:300px;">
                <input type="text" class="form-control border-0 ps-3"
                       placeholder="Buscar nombre o codigo..."
                       @bind="busqueda" @bind:event="oninput" />
            </div>
            <button class="btn btn-light shadow-sm fw-bold px-4 rounded-pill d-flex align-items-center" @onclick="AbrirModal">
                <i class="bi bi-plus-circle-fill me-2 text-success"></i>Nuevo Producto
            </button>
        </div>
    </div>

    @* --- BARRA DE FILTROS --- *@
    <div class="d-flex flex-wrap gap-2 my-3 align-items-center bg-white p-3 rounded-4 shadow-sm border">
        <span class="small fw-bold text-muted me-2"><i class="bi bi-filter-left me-1"></i>FILTRAR POR:</span>

        @* Dropdown Categorías *@
        <div class="position-relative">
            <button class="btn btn-light border shadow-sm dropdown-toggle rounded-pill px-3" type="button"
                    @onclick="() => { mostrarDropCategoria = !mostrarDropCategoria; mostrarDropEstado = false; }">
                <i class="bi bi-tag-fill me-2 text-primary"></i>
                @(idCategoriaFiltro == 0 ? "Todas las Categorías" : categorias.FirstOrDefault(c => c.IdCategoria == idCategoriaFiltro)?.Nombre)
            </button>
            @if (mostrarDropCategoria)
            {
                <div class="position-absolute bg-white shadow-lg border-0 rounded-4 p-3 mt-1" style="width:280px; z-index:1055;">
                    <div class="input-group input-group-sm mb-2">
                        <span class="input-group-text bg-white"><i class="bi bi-search small"></i></span>
                        <input type="text" class="form-control" placeholder="Buscar categoría..."
                               @bind="busquedaCategoria" @bind:event="oninput" />
                    </div>
                    <div style="max-height:200px; overflow-y:auto;">
                        <button class="dropdown-item rounded-3 @(idCategoriaFiltro == 0 ? "active" : "")"
                                @onclick="() => { idCategoriaFiltro = 0; mostrarDropCategoria = false; }">
                            Todas las categorías
                        </button>
                        <hr class="dropdown-divider" />
                        @foreach (var cat in CategoriasFiltradasMenu)
                        {
                            <button class="dropdown-item rounded-3 @(idCategoriaFiltro == cat.IdCategoria ? "active" : "")"
                                    @onclick="() => { idCategoriaFiltro = cat.IdCategoria; mostrarDropCategoria = false; }">
                                @cat.Nombre
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        @* Dropdown Estado *@
        <div class="position-relative">
            <button class="btn btn-light border shadow-sm dropdown-toggle rounded-pill px-3" type="button"
                    @onclick="() => { mostrarDropEstado = !mostrarDropEstado; mostrarDropCategoria = false; }">
                <i class="bi bi-toggle-on me-2 text-warning"></i>
                @(estadoFiltro == null ? "Todos los Estados" : (estadoFiltro.Value ? "Solo Activos" : "Solo Inactivos"))
            </button>
            @if (mostrarDropEstado)
            {
                <div class="position-absolute bg-white shadow-lg rounded-4 p-2 mt-1" style="min-width:180px; z-index:1055;">
                    <button class="dropdown-item rounded-3 @(estadoFiltro == null ? "active" : "")"
                            @onclick="() => { estadoFiltro = null; mostrarDropEstado = false; }">
                        Todos
                    </button>
                    <button class="dropdown-item rounded-3 @(estadoFiltro == true ? "active" : "")"
                            @onclick="() => { estadoFiltro = true; mostrarDropEstado = false; }">
                        Activos
                    </button>
                    <button class="dropdown-item rounded-3 @(estadoFiltro == false ? "active" : "")"
                            @onclick="() => { estadoFiltro = false; mostrarDropEstado = false; }">
                        Inactivos
                    </button>
                </div>
            }
        </div>

        <button class="btn btn-outline-secondary btn-sm rounded-pill px-3 ms-auto" @onclick="LimpiarFiltros">
            <i class="bi bi-trash3 me-1"></i>Limpiar Filtros
        </button>
    </div>

    @* --- TABLA --- *@
    <div class="card prod-card p-4">
        @if (productos == null)
        {
            <div class="alert alert-info shadow-sm">Cargando productos...</div>
        }
        else if (!ProductosFiltrados.Any())
        {
            <div class="alert alert-warning shadow-sm">No se encontraron productos con los filtros aplicados.</div>
        }
        else
        {
            <div class="table-responsive" style="max-height:60vh;">
                <table class="table table-modern align-middle">
                    <thead>
                        <tr>
                            <th class="text-center">CÓDIGO</th>
                            <th>NOMBRE</th>
                            <th class="text-end">PRECIO</th>
                            <th class="text-center">STOCK</th>
                            <th>CATEGORÍA</th>
                            <th class="text-center">ESTADO</th>
                            <th class="text-center">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in ProductosFiltrados)
                        {
                            <tr class="@(p.Activo ? "" : "fila-inactiva")">
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(p.CodigoBarras))
                                    {
                                        <img src="data:image/png;base64,@BarcodeGenerator.GenerarBase64(p.CodigoBarras)" style="max-height:40px;" />
                                        <div class="text-muted" style="font-size:0.65rem;">@p.CodigoBarras</div>
                                    }
                                </td>
                                <td class="fw-bold text-dark">@p.Nombre</td>
                                <td class="text-end fw-bold text-primary">@p.PrecioVenta.ToString("N2") Bs.</td>
                                <td class="text-center">
                                    <span class="badge @(p.StockActual <= p.StockMinimo ? "bg-danger" : "bg-success-subtle text-success") px-3 rounded-pill">
                                        @p.StockActual
                                    </span>
                                </td>
                                <td><span class="badge bg-light text-dark fw-normal border">@(p.Categoria?.Nombre ?? "N/A")</span></td>
                                <td class="text-center">
                                    @if (p.Activo)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success px-3">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3">Inactivo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-outline-info btn-sm rounded-pill px-3 me-1" @onclick="() => VerDetalle(p)">
                                        <i class="bi bi-eye me-1"></i>Ver
                                    </button>
                                    <button class="btn btn-outline-warning btn-sm rounded-pill px-3 me-1" @onclick="() => EditarProducto(p)">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </button>
                                    @if (p.Activo)
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3" @onclick="() => InhabilitarProducto(p)">
                                            <i class="bi bi-slash-circle me-1"></i>Inhabilitar
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-success btn-sm rounded-pill px-3" @onclick="() => HabilitarProducto(p)">
                                            <i class="bi bi-check-circle me-1"></i>Habilitar
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* --- MODAL: REGISTRO / EDICIÓN --- *@
@if (mostrarModal)
{
    <div class="modal fade show d-block modal-blur" tabindex="-1">
        <div class="modal-dialog modal-prod modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content modal-prod-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-box-seam me-2"></i>@(esEdicion ? "Editar Producto" : "Registrar Nuevo Producto")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="producto" OnValidSubmit="Guardar">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(error))
                        {
                            <div class="alert alert-danger py-2 rounded-3">@error</div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Código de Barras</label>
                                <div class="input-group shadow-sm">
                                    <InputText class="form-control bg-light" @bind-Value="producto.CodigoBarras" readonly="true" />
                                    @if (!esEdicion)
                                    {
                                        <button class="btn btn-dark" type="button" @onclick="GenerarCodigo">Generar</button>
                                    }
                                </div>
                                <div class="border rounded-3 p-2 text-center bg-light mt-2" style="min-height:70px;">
                                    @if (!string.IsNullOrEmpty(producto.CodigoBarras))
                                    {
                                        <img src="data:image/png;base64,@BarcodeGenerator.GenerarBase64(producto.CodigoBarras)" style="max-height:50px;" />
                                        <div class="small fw-bold">@producto.CodigoBarras</div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nombre del Producto</label>
                                <InputText class="form-control shadow-sm" @bind-Value="producto.Nombre" />
                                <label class="form-label fw-bold mt-2">Categoría</label>
                                <InputSelect class="form-select shadow-sm" @bind-Value="producto.IdCategoria">
                                    <option value="0">Seleccione una categoría...</option>
                                    @foreach (var cat in categorias)
                                    {
                                        <option value="@cat.IdCategoria">@cat.Nombre</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Unidad de Medida</label>
                                <InputText class="form-control shadow-sm" @bind-Value="producto.UnidadMedida" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-bold">Precio Compra</label>
                                <InputNumber class="form-control shadow-sm" @bind-Value="producto.PrecioCompra" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-bold">Precio Venta</label>
                                <InputNumber class="form-control shadow-sm" @bind-Value="producto.PrecioVenta" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Stock Actual</label>
                                <InputNumber class="form-control shadow-sm" @bind-Value="producto.StockActual" readonly="@esEdicion" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Stock Mínimo</label>
                                <InputNumber class="form-control shadow-sm" @bind-Value="producto.StockMinimo" />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label fw-bold">Descripción</label>
                            <InputTextArea class="form-control shadow-sm" @bind-Value="producto.Descripcion" rows="2" />
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                            <button type="button" class="btn btn-secondary rounded-pill px-4" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-success rounded-pill px-4">
                                <i class="bi bi-check2 me-1"></i>@(esEdicion ? "Guardar Cambios" : "Registrar")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@* --- MODAL: DETALLE --- *@
@if (mostrarDetalle)
{
    <div class="modal fade show d-block modal-blur" tabindex="-1">
        <div class="modal-dialog modal-prod modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content modal-prod-content border-0 shadow-lg">
                <div class="modal-header bg-info text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-clipboard-data me-2"></i>Ficha del Producto</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarDetalle = false"></button>
                </div>
                <div class="modal-body bg-light">
                    <div class="text-center mb-3 p-3 border rounded-4 bg-white shadow-sm">
                        <img src="data:image/png;base64,@BarcodeGenerator.GenerarBase64(producto.CodigoBarras)" style="max-height:80px;" />
                        <h4 class="mt-2 text-primary fw-bold">@producto.Nombre</h4>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-group shadow-sm mb-3 rounded-3 overflow-hidden">
                                <li class="list-group-item bg-dark text-white fw-bold">Información Básica</li>
                                <li class="list-group-item"><strong>Código:</strong> @producto.CodigoBarras</li>
                                <li class="list-group-item"><strong>Categoría:</strong> @(producto.Categoria?.Nombre ?? "General")</li>
                                <li class="list-group-item"><strong>Unidad:</strong> @producto.UnidadMedida</li>
                                <li class="list-group-item">
                                    <strong>Estado:</strong>
                                    <span class="badge @(producto.Activo ? "bg-success" : "bg-danger") ms-1">
                                        @(producto.Activo ? "ACTIVO" : "INACTIVO")
                                    </span>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-group shadow-sm mb-3 rounded-3 overflow-hidden">
                                <li class="list-group-item bg-dark text-white fw-bold">Precios e Inventario</li>
                                <li class="list-group-item d-flex justify-content-between"><strong>Precio Compra:</strong> <span>@producto.PrecioCompra.ToString("N2") Bs.</span></li>
                                <li class="list-group-item d-flex justify-content-between text-success fw-bold"><strong>Precio Venta:</strong> <span>@producto.PrecioVenta.ToString("N2") Bs.</span></li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Stock Actual:</strong>
                                    <span class="badge @(producto.StockActual <= producto.StockMinimo ? "bg-danger" : "bg-success") fs-6">@producto.StockActual</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between"><strong>Stock Mínimo:</strong> <span>@producto.StockMinimo</span></li>
                            </ul>
                        </div>
                    </div>
                    <div class="card shadow-sm rounded-3 overflow-hidden">
                        <div class="card-header bg-dark text-white fw-bold">Descripción</div>
                        <div class="card-body bg-white">
                            <p class="card-text text-muted">@(string.IsNullOrEmpty(producto.Descripcion) ? "Sin descripción." : producto.Descripcion)</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-white">
                    <button class="btn btn-info text-white w-100 rounded-pill fw-bold shadow-sm" @onclick="() => mostrarDetalle = false">Cerrar Ficha</button>
                </div>
            </div>
        </div>
    </div>
}