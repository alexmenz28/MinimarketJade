@page "/reportes/kpi-productividad"
@using MinimarketJade.Web.Data.Entities
@using MinimarketJade.Web.Services.Compras
@inject ICompraService CompraService
@rendermode InteractiveServer

<div class="container py-3">
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Participación por Proveedor (60% del Total)</h5>
            <p class="card-text text-muted">Solo indicador: porcentaje por proveedor con gráfico de barras.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (GastosPorProveedor == null)
            {
                <div>Cargando...</div>
            }
            else
            {
                <div class="bar-chart">
                    @{
                        var top = GastosPorProveedor.OrderByDescending(x => x.Porcentaje).Take(3).ToList();
                    }
                    @foreach (var g in top)
                    {
                        <div class="bar-row mb-2">
                            <div class="d-flex justify-content-between">
                                <div class="fw-bold">@g.RazonSocial</div>
                                <div class="text-muted">@g.Porcentaje.ToString("0.0")%</div>
                            </div>
                            <div class="bar-container mt-1">
                                <div class="bar-fill" style="width:@g.Porcentaje.ToString("0.##")%"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<GastoProveedorDto>? GastosPorProveedor;
    private List<DonutSegment> DonutSegments = new();
    private decimal ConcentracionPercent = 0m;
    private string TotalComprasFormateado = "Bs. 0";
    private int NumProveedores = 0;
    private string ProveedorPrincipal = "-";
    private decimal ProveedorPrincipalPercent = 0m;
    private List<GastoProveedorDto> Top3Proveedores = new();

    private System.Threading.CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new System.Threading.CancellationTokenSource();
        await LoadAsync();
        _ = AutoRefreshAsync(_cts.Token);
    }

    private async Task LoadAsync()
    {
        var hasta = DateTime.UtcNow;
        var desde = hasta.AddMonths(-3);
        GastosPorProveedor = await CompraService.ObtenerGastoPorProveedorAsync(desde, hasta);
        var total = GastosPorProveedor.Sum(x => x.TotalGastado);
        TotalComprasFormateado = $"Bs. {total.ToString("N0")}";
        NumProveedores = GastosPorProveedor.Count;
        ConcentracionPercent = (decimal)await CompraService.ObtenerConcentracionTop3ProveedoresAsync(desde, hasta);
        if (GastosPorProveedor.Any())
        {
            var top = GastosPorProveedor.First();
            ProveedorPrincipal = top.RazonSocial ?? "-";
            ProveedorPrincipalPercent = top.Porcentaje;
            Top3Proveedores = GastosPorProveedor.OrderByDescending(x => x.Porcentaje).Take(3).ToList();
        }

        DonutSegments.Clear();
        var colors = new[] { "#1f77b4", "#2ca02c", "#ff7f0e", "#d62728", "#9edae5" };
        double start = 0;
        var list = GastosPorProveedor.Take(5).ToList();
        foreach (var item in list.Select((v, i) => (v, i)))
        {
            var g = item.v; var idx = item.i;
            var sweep = (double)(g.TotalGastado / (total == 0 ? 1 : total)) * 360.0;
            DonutSegments.Add(CreateDonutSegment(21,21,15, start, start + sweep, colors[idx % colors.Length]));
            start += sweep;
        }

        StateHasChanged();
    }

    private DonutSegment CreateDonutSegment(double cx, double cy, double r, double startAngle, double endAngle, string color)
    {
        double s = (Math.PI / 180) * (startAngle - 90);
        double e = (Math.PI / 180) * (endAngle - 90);
        double x1 = cx + r * Math.Cos(s);
        double y1 = cy + r * Math.Sin(s);
        double x2 = cx + r * Math.Cos(e);
        double y2 = cy + r * Math.Sin(e);
        var large = endAngle - startAngle > 180 ? 1 : 0;
        var path = $"M {x1} {y1} A {r} {r} 0 {large} 1 {x2} {y2}";
        return new DonutSegment { Path = path, Color = color };
    }

    private async Task AutoRefreshAsync(System.Threading.CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(30), token).ContinueWith(_ => { });
                if (token.IsCancellationRequested) break;
                await LoadAsync();
            }
            catch (TaskCanceledException) { break; }
            catch { }
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private class DonutSegment { public string Path { get; set; } = string.Empty; public string Color { get; set; } = "#ccc"; }
}
