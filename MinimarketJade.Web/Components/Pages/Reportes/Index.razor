@page "/reportes"
@rendermode InteractiveServer
@using MinimarketJade.Web.Services.Auth
@using MinimarketJade.Web.Services.Reportes
@using ApexCharts
<PageTitle>Reportes - Minimarket Jade</PageTitle>

@if (!Auth.IsAdministrador)
{
    <div class="container mt-3">
        <div class="alert alert-danger">No tiene permisos para acceder a este módulo.</div>
    </div>
}
else
{
    <div class="container-fluid mt-3 px-4">
        <h2 class="fw-bold">Dashboard</h2>
        <div class="row g-3">

            @* KPI 1 - Cuotas de ventas *@
            <div class="col-md-5">
                <div class="card p-3 mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold mb-0">Cuotas de ventas</h6>
                        <span class="text-muted" style="font-size:11px;">Meta diaria: @metaDiaria.ToString("N2") Bs.</span>
                    </div>
                    <div class="d-flex gap-2 mb-2">
                        <div class="bg-light rounded p-2 flex-fill">
                            <div class="text-muted" style="font-size:11px;">Hoy</div>
                            <div class="fw-bold" style="font-size:18px;">@totalHoy.ToString("N2") Bs.</div>
                            <span class="badge @(cumplimientoHoy >= 100 ? "bg-success" : "bg-danger")" style="font-size:10px;">
                                @cumplimientoHoy.ToString("N0")%
                            </span>
                        </div>
                        <div class="bg-light rounded p-2 flex-fill">
                            <div class="text-muted" style="font-size:11px;">Vs ayer</div>
                            <div class="fw-bold @(variacion >= 0 ? "text-success" : "text-danger")" style="font-size:18px;">
                                @(variacion >= 0 ? "+" : "")@variacion.ToString("N1")%
                            </div>
                            <span class="text-muted" style="font-size:11px;">@(variacion >= 0 ? "Subió" : "Bajó")</span>
                        </div>
                    </div>
                    @if (opcionesGrafica != null)
                    {
                        <div style="height: 200px; max-width: 100%; overflow: hidden;">
                            <ApexChart TItem="IngresosDiarios"
                                       Options="opcionesGrafica"
                                       Height="180">
                                <ApexPointSeries TItem="IngresosDiarios"
                                                 Items="ingresosDiarios"
                                                 Name="Ingresos"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="@(i => i.Fecha.ToString("dd/MM"))"
                                                 YValue="@(i => i.Total)"
                                                 Color="#1D9E75"
                                                 Stroke="@(new SeriesStroke { Width = 4, Color = "#1D9E75" })" />
                            </ApexChart>
                        </div>
                    }
                </div>
            </div>
            @* KPI 2- Productividad por vendedor *@
            <div class="col-auto">
                <div class="card p-3 mb-3" style="cursor:pointer;" @onclick="() => mostrarTodosVendedores = true">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="mb-2">
                            <h6 class="fw-bold mb-0">Rendimiento del personal</h6>
                            <span class="text-muted" style="font-size:11px;">Meta semanal: 3.000,00 Bs.</span>
                        </div>
                    </div>

                    @if (vendedores.Any())
                    {
                        <div class="d-flex gap-3 mt-2">

                            @* Mejor vendedor *@
                            <div class="text-center">
                                <div class="text-muted mb-1" style="font-size:11px;">Mejor vendedor</div>
                                <svg viewBox="0 0 36 36" style="width:80px;height:80px;">
                                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                          fill="none" stroke="#eee" stroke-width="3" />
                                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                          fill="none" stroke="#1D9E75" stroke-width="3"
                                          stroke-dasharray="@(Math.Min(vendedores.First().Porcentaje, 100).ToString("N0")), 100" />
                                    <text x="18" y="20.5" text-anchor="middle"
                                          style="font-size:8px;font-weight:bold;fill:#1D9E75;">
                                        @vendedores.First().Porcentaje.ToString("N0")%
                                    </text>
                                </svg>
                                <div style="font-size:12px;" class="fw-bold">@vendedores.First().NombreVendedor</div>
                                <div style="font-size:11px;" class="text-muted">@vendedores.First().TotalVentas.ToString("N2") Bs.</div>
                            </div>

                            @* Menor vendedor *@
                            <div class="text-center">
                                <div class="text-muted mb-1" style="font-size:11px;">Menor vendedor</div>
                                <svg viewBox="0 0 36 36" style="width:80px;height:80px;">
                                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                          fill="none" stroke="#eee" stroke-width="3" />
                                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                          fill="none"
                                          stroke="@(vendedores.Last().Porcentaje >= 100 ? "#1D9E75" : "#dc3545")"
                                          stroke-width="3"
                                          stroke-dasharray="@(Math.Min(vendedores.Last().Porcentaje, 100).ToString("N0")), 100" />
                                    <text x="18" y="20.5" text-anchor="middle"
                                          style="font-size:8px;font-weight:bold;fill:@(vendedores.Last().Porcentaje >= 100 ? "#1D9E75" : "#dc3545");">
                                        @vendedores.Last().Porcentaje.ToString("N0")%
                                    </text>
                                </svg>
                                <div style="font-size:12px;" class="fw-bold">@vendedores.Last().NombreVendedor</div>
                                <div style="font-size:11px;" class="text-muted">@vendedores.Last().TotalVentas.ToString("N2") Bs.</div>
                            </div>

                        </div>
                    }
                    else
                    {
                        <p class="text-muted small">Sin ventas esta semana.</p>
                    }
                </div>
            </div>

        </div>
    </div>

    @* Modal todos los vendedores *@
    @if (mostrarTodosVendedores)
    {
        <div class="modal fade show d-block modal-blur" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold">Rendimiento del Personal</h5>
                        <button type="button" class="btn-close" @onclick="() => mostrarTodosVendedores = false"></button>
                    </div>
                    <div class="modal-body p-4">
                        <p class="text-muted small mb-3">Meta semanal: 3.000,00 Bs.</p>
                        <div class="d-flex flex-wrap justify-content-around gap-3">
                            @foreach (var v in vendedores)
                            {
                                <div class="text-center">
                                    <svg viewBox="0 0 36 36" style="width:80px;height:80px;">
                                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                              fill="none" stroke="#eee" stroke-width="3" />
                                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                              fill="none"
                                              stroke="@(v.Porcentaje >= 100 ? "#1D9E75" : "#dc3545")"
                                              stroke-width="3"
                                              stroke-dasharray="@(Math.Min(v.Porcentaje, 100).ToString("N0")), 100" />
                                        <text x="18" y="20.5" text-anchor="middle"
                                              style="font-size:8px;font-weight:bold;fill:@(v.Porcentaje >= 100 ? "#1D9E75" : "#dc3545");">
                                            @v.Porcentaje.ToString("N0")%
                                        </text>
                                    </svg>
                                    <div class="fw-bold" style="font-size:13px;">@v.NombreVendedor</div>
                                    <div class="text-muted" style="font-size:11px;">@v.TotalVentas.ToString("N2") Bs.</div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button class="btn btn-secondary w-100 rounded-pill" @onclick="() => mostrarTodosVendedores = false">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}