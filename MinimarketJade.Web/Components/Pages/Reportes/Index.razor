@page "/reportes"
@rendermode InteractiveServer
<PageTitle>Reportes - Minimarket Jade</PageTitle>

<h2>Reportes y KPI</h2>
<p>Indicadores, ventas y stock crítico.</p>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card dashboard-card p-3">
            <h5>KPI 1 — Precio de Compra Promedio por Producto</h5>
            <p class="text-muted">Módulo: Productos / Compras · Medición: Mensual</p>
            <NavLink class="btn btn-primary" href="/reportes/kpi-precio-promedio">Abrir KPI 1</NavLink>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card dashboard-card p-3">
            <h5>KPI 2 — Productividad de Compra por Proveedor</h5>
            <p class="text-muted">Módulo: Proveedores / Compras · Medición: Trimestral</p>
            <NavLink class="btn btn-primary" href="/reportes/kpi-productividad">Abrir KPI 2</NavLink>
        </div>
    </div>
</div>
