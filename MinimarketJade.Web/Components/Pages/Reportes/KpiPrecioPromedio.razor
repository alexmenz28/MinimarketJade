@page "/reportes/kpi-precio-promedio"
@using MinimarketJade.Web.Data.Entities
@using MinimarketJade.Web.Services.Compras
@inject ICompraService CompraService
@rendermode InteractiveServer

<div class="container py-3">
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">KPI 1 — Precio de Compra Promedio por Producto</h5>
            <p class="card-text text-muted">Módulo ERP: Productos / Compras · Responsable: Encargado de Compras · Medición: Mensual</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <div class="small text-muted mb-2">Precio Estándar por Categoría</div>
                    @if (CategoriasPrecios == null)
                    {
                        <div>Cargando...</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var c in CategoriasPrecios)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <div class="fw-bold">@c.NombreCategoria</div>
                                    <div>Bs. @c.PrecioEstandar.ToString("0.00")</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="small text-muted mb-2">SEMÁFORO DE CONTROL</div>
                    <p class="text-muted">Se muestra únicamente el precio estándar por categoría en esta vista.</p>
                </div>
            </div>
        </div>
    </div>

</div>

@code {
    private List<CategoriaPrecioDto>? CategoriasPrecios;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        CategoriasPrecios = await CompraService.ObtenerPrecioEstandarPorCategoriaAsync();
    }
}
